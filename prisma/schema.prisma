// ============================================================
// KantinKlik — prisma/schema.prisma
// Stack: Prisma 6 + PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum MenuCategoryType {
  FOOD
  DRINK
  SNACK
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  READY
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ONLINE
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum SettlementMode {
  MANUAL
  AUTO
}

// ============================================================
// MODELS
// ============================================================

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  passwordHash   String
  name           String
  whatsappNumber String
  role           Role     @default(CUSTOMER)
  isVerified     Boolean  @default(false)
  tokenVersion   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendorProfile    VendorProfile?
  ordersAsCustomer Order[]        @relation("CustomerOrders")
  ratings          Rating[]

  @@map("users")
}

model VendorProfile {
  id                Int            @id @default(autoincrement())
  userId            Int            @unique
  canteenNumber     Int            @unique
  canteenName       String
  description       String?
  logoUrl           String?
  isActive          Boolean        @default(true)
  settlementMode    SettlementMode @default(MANUAL)
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menus   Menu[]
  orders  Order[]  @relation("VendorOrders")
  ratings Rating[]

  @@map("vendor_profiles")
}

model MenuCategory {
  id   Int              @id @default(autoincrement())
  name String           @unique
  type MenuCategoryType

  menus Menu[]

  @@map("menu_categories")
}

model Menu {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  categoryId  Int
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  stock       Int      @default(0)
  isAvailable Boolean  @default(true)
  avgRating   Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor     VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   MenuCategory  @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  ratings    Rating[]

  @@index([vendorId])
  @@index([categoryId])
  @@map("menus")
}

model Order {
  id               Int           @id @default(autoincrement())
  orderCode        String        @unique
  customerId       Int
  vendorId         Int
  status           OrderStatus   @default(PENDING)
  paymentMethod    PaymentMethod @default(CASH)
  paymentStatus    PaymentStatus @default(UNPAID)
  paymentReference String?
  subtotal         Decimal       @db.Decimal(10, 2)
  notes            String?
  acceptedAt       DateTime?
  readyAt          DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  paidAt           DateTime?
  rejectionReason  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  serviceFeeRate   Decimal       @default(0) @db.Decimal(5, 4)
  serviceFee       Decimal       @default(0) @db.Decimal(10, 2)
  platformFee      Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal       @db.Decimal(10, 2)

  customer   User          @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor     VendorProfile @relation("VendorOrders", fields: [vendorId], references: [id])
  orderItems OrderItem[]

  @@index([vendorId, status])
  @@index([customerId, status])
  @@index([orderCode])
  @@map("orders")
}

model OrderItem {
  id               Int     @id @default(autoincrement())
  orderId          Int
  menuId           Int
  menuNameSnapshot String
  priceSnapshot    Decimal @db.Decimal(10, 2)
  quantity         Int
  subtotal         Decimal @db.Decimal(10, 2)

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu   Menu    @relation(fields: [menuId], references: [id])
  rating Rating?

  @@index([orderId])
  @@map("order_items")
}

model Rating {
  id          Int      @id @default(autoincrement())
  orderItemId Int      @unique
  customerId  Int
  menuId      Int
  vendorId    Int
  stars       Int
  review      String?
  createdAt   DateTime @default(now())

  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  customer      User          @relation(fields: [customerId], references: [id])
  menu          Menu          @relation(fields: [menuId], references: [id])
  vendorProfile VendorProfile @relation(fields: [vendorId], references: [id])

  @@index([menuId])
  @@index([vendorId])
  @@map("ratings")
}

model OtpToken {
  id           Int       @id @default(autoincrement())
  email        String
  codeHash     String
  purpose      String    @default("REGISTER")
  attemptCount Int       @default(0)
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@map("otp_tokens")
}

model OtpRateLimit {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  requestsInWindow Int      @default(0)
  windowStartAt    DateTime
  lastRequestAt    DateTime

  @@map("otp_rate_limits")
}
